APP_NAME=RelayForge
ENVIRONMENT=local
DEBUG=true

SECRET_KEY=change-me-please-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

DATABASE_URL=postgresql+asyncpg://relayforge:relayforge@db:5432/relayforge
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
WEBHOOK_SIGNING_SECRET=change-me-please-change-in-production

RATE_LIMIT_DEFAULT=100
API_V1_PREFIX=/api/v1
